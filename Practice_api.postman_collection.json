			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var jsonData = pm.response.json();\r",
							"pm.environment.set(\"id\",jsonData.bookingid);\r",
							"\r",
							"pm.test(\"Status code is 200\",function(){\r",
							"    pm.response.to.have.status(200);\r",
							"})\r",
							"\r",
							"pm.test(\"Status code is 403\",function(){\r",
							"    pm.response.to.have.status(403);\r",
							"})\r",
							"\r",
							"pm.test(\"Response time is 283\",function(){\r",
							"    pm.expect(pm.response.responseTime).to.be.below(2200);\r",
							"})\r",
							"\r",
							"pm.test(\"Status code is success (2xx)\", function () {\r",
							"    pm.expect(pm.response.code).to.be.within(200, 299);\r",
							"});\r",
							"\r",
							"pm.test(\"Your first name is Emon\",function(){\r",
							"    var jsonData = pm.response.json();\r",
							"    pm.expect(jsonData.booking.firstname).to.eql('Emon');\r",
							"})\r",
							"\r",
							"pm.test(\"Your Last name is Brown\",function(){\r",
							"    var jsonData = pm.response.json();\r",
							"    pm.expect(jsonData.booking.lastname).to.eql('Brown');\r",
							"})\r",
							"\r",
							"pm.test(\"Your total price is 111\",function(){\r",
							"    var jsonData = pm.response.json();\r",
							"    pm.expect(jsonData.booking.totalprice).to.eql(111);\r",
							"})\r",
							"\r",
							"pm.test(\"Your fristname is exist\",function(){\r",
							"    var jsonData = pm.response.json();\r",
							"    pm.expect(jsonData.booking).to.have.property(\"firstname\");\r",
							"})\r",
							"\r",
							"pm.test(\"Your name is empty\",function(){\r",
							"    var jsonData = pm.response.json();\r",
							"    pm.expect(jsonData.booking.firstname).to.not.be.empty;\r",
							"})\r",
							"\r",
							"pm.test(\"Your deposit paid\",function(){\r",
							"    var jsonData = pm.response.json();\r",
							"    pm.expect(jsonData.booking.depositpaid).to.eql(true);\r",
							"})\r",
							"\r",
							"pm.test(\"Your checkin time is 2018-01-01\",function(){\r",
							"    var jsonData = pm.response.json();\r",
							"    pm.expect(jsonData.booking.bookingdates.checkin).to.eql(\"2018-01-01\");\r",
							"})\r",
							"\r",
							"pm.test(\"Your additional needs is breakfast\",function(){\r",
							"    var jsonData = pm.response.json();\r",
							"    pm.expect(jsonData.booking.additionalneeds).to.eql(\"Breakfast\");\r",
							"})"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
